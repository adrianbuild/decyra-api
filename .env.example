# App runtime connection — unprivileged role, RLS enforced (Task 2.2c).
# Dev password is seeded by docker/init-test-db.sql (LOCAL DEV ONLY).
DATABASE_URL=postgresql://decyra_app:decyra_app_dev@localhost:55432/decyra
# Migrations + model seed — privileged role (DDL, GRANT, upsert models).
# decyra_app lacks these on purpose (loud failure if used here).
MIGRATION_DATABASE_URL=postgresql://postgres:postgres@localhost:55432/decyra

# Supabase Auth (Project URL aus Settings -> API im Supabase Dashboard).
# JWKS-Endpoint wird abgeleitet: {SUPABASE_URL}/auth/v1/.well-known/jwks.json
# Algorithm: ES256 (ECC P-256).
SUPABASE_URL=
# Optional, Default = "authenticated":
# SUPABASE_JWT_AUDIENCE=
# Optional, Default = {SUPABASE_URL}/auth/v1:
# SUPABASE_JWT_ISSUER=

# Audit verify token (Task 3.2) — HS256-signed JWT for /v/{token}.
# Any random 32+ byte string; NOT the Supabase JWT secret.
AUDIT_VERIFY_SECRET=
# Optional, Default = 2592000s = 30 days:
# AUDIT_VERIFY_TOKEN_DEFAULT_TTL_SECONDS=

# Mail (Task 2.3). Defaults point at the local Mailpit catcher
# (docker compose up -d mailpit; UI at http://localhost:8025). Prod
# swaps SMTP_HOST/PORT/FROM for a real relay.
# SMTP_HOST=localhost
# SMTP_PORT=1025
# MAIL_FROM=noreply@decyra.local
# Base URL used to build the invitation link in the email:
# APP_BASE_URL=http://localhost:3000

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
MISTRAL_API_KEY=
# Vertex AI EU access pending — the model "vertex_ai/gemini-3.5-flash-tbd"
# is seeded with enabled=false. Flip enabled=true and re-run
# `python -m app.seed_models` once the key is set and the Vertex
# pricing in app/seed_models.py is corrected.
GOOGLE_API_KEY=

# PII detection (Task 4.5a). Presidio analyzer as a Docker service
# (docker compose up -d presidio). If UNSET, the PII check is treated as
# "unavailable" and sovereign mode FAIL-SAFE reroutes every request to the
# sovereign model — safe, but degraded. Point this at the running analyzer:
PRESIDIO_URL=http://localhost:5002
# Optional, Default = 0.4 (below Presidio's 0.5 default, biased to detect):
# PII_SCORE_THRESHOLD=0.4
# Optional, Default = mistral/mistral-large-latest (validated enabled +
# sovereign_eligible at use):
# SOVEREIGN_MODEL=mistral/mistral-large-latest

# Document storage (Task 5.1). Raw uploaded files are written here under
# {workspace_id}/{uuid}{ext}. Default ./var/documents (gitignored, dev only) —
# set an absolute path OUTSIDE the repo in production.
# DOCUMENT_STORAGE_DIR=/srv/decyra/documents
# Optional, Default = 26214400 (25 MiB), enforced server-side per chunk:
# MAX_UPLOAD_BYTES=26214400
