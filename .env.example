DATABASE_URL=postgresql://postgres:postgres@localhost:55432/decyra
# NOTE: ab Task 2.2 wechselt der App-Connection-User auf decyra_app
# (NOSUPERUSER NOBYPASSRLS). Migrationen laufen weiter als postgres.

# Supabase Auth (Project URL aus Settings -> API im Supabase Dashboard).
# JWKS-Endpoint wird abgeleitet: {SUPABASE_URL}/auth/v1/.well-known/jwks.json
# Algorithm: ES256 (ECC P-256).
SUPABASE_URL=
# Optional, Default = "authenticated":
# SUPABASE_JWT_AUDIENCE=
# Optional, Default = {SUPABASE_URL}/auth/v1:
# SUPABASE_JWT_ISSUER=

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
MISTRAL_API_KEY=
GOOGLE_API_KEY=
