# App runtime connection — unprivileged role, RLS enforced (Task 2.2c).
# Dev password is seeded by docker/init-test-db.sql (LOCAL DEV ONLY).
DATABASE_URL=postgresql://decyra_app:decyra_app_dev@localhost:55432/decyra
# Migrations + model seed — privileged role (DDL, GRANT, upsert models).
# decyra_app lacks these on purpose (loud failure if used here).
MIGRATION_DATABASE_URL=postgresql://postgres:postgres@localhost:55432/decyra

# Supabase Auth (Project URL aus Settings -> API im Supabase Dashboard).
# JWKS-Endpoint wird abgeleitet: {SUPABASE_URL}/auth/v1/.well-known/jwks.json
# Algorithm: ES256 (ECC P-256).
SUPABASE_URL=
# Optional, Default = "authenticated":
# SUPABASE_JWT_AUDIENCE=
# Optional, Default = {SUPABASE_URL}/auth/v1:
# SUPABASE_JWT_ISSUER=

# Audit verify token (Task 3.2) — HS256-signed JWT for /v/{token}.
# Any random 32+ byte string; NOT the Supabase JWT secret.
AUDIT_VERIFY_SECRET=
# Optional, Default = 2592000s = 30 days:
# AUDIT_VERIFY_TOKEN_DEFAULT_TTL_SECONDS=

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
MISTRAL_API_KEY=
# Vertex AI EU access pending — the model "vertex_ai/gemini-3.5-flash-tbd"
# is seeded with enabled=false. Flip enabled=true and re-run
# `python -m app.seed_models` once the key is set and the Vertex
# pricing in app/seed_models.py is corrected.
GOOGLE_API_KEY=
